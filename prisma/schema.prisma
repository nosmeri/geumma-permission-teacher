datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PermitStatus {
  PENDING
  APPROVED
  REJECTED
}

model Teacher {
  id          String         @id @default(uuid())
  name        String
  subject     String
  deviceToken String         @unique
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  permits     Permit[]       @relation("TeacherPermits")
}

model Permit {
  id         String       @id @default(uuid())
  date       DateTime     @db.Date
  periods    String[]
  location   String
  reason     String
  applicants Json
  status     PermitStatus @default(PENDING)
  approverId String?
  approver   Teacher?     @relation("TeacherPermits", fields: [approverId], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Location {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}
